<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.anka.os.launcher">

    <!-- İzinler -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_anka"
        android:label="@string/app_name"
        android:theme="@style/AnkaTheme"
        android:persistent="true">

        <!-- Ana Launcher Activity -->
        <activity
            android:name=".LauncherActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:stateNotNeeded="true"
            android:resumeWhilePausing="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustPan">

            <!-- Bu iki intent-filter Activity'yi HOME (ana ekran) yapar -->
            <intent-filter android:priority="1">
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.MONKEY" />
            </intent-filter>
        </activity>

        <!-- Boot alıcı: Anka OS servisi her açılışta başlatılır -->
        <receiver
            android:name=".BootReceiver"
            android:exported="false">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Arka plan servisi -->
        <service
            android:name=".AnkaService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>
</manifest>
