// core/checkup.c
#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>

// Dışarıdan gelecek fonksiyonları derleyiciye tanıtıyoruz
extern int get_battery_level();
extern void speak(const char* text);

// --- DONANIM DEDEKTİFİ VE SAĞLIK RAPORU ---
void run_initial_checkup() {
    printf("[SİSTEM]: İç donanım sinyalleri gönderiliyor...\n");
    
    // Geçici dosyaları baştan temizle ki eski okumalar karışmasın
    system("rm -f /data/local/tmp/checkup_msg /data/local/tmp/batt_msg");
    system("touch /data/local/tmp/checkup_msg"); // Dosya yoksa bile okuma hatası vermesin

    // 1. SES TUŞLARI (Kullanıcıya özel dürüst yorum)
    if (system("test -e /dev/input/event0") != 0) { // Basit bir tuş hattı testi
        printf("\033[1;33m[UYARI]\033[0m Ses tuşları cevap vermiyor kanka.\n");
        system("echo 'Ses tuşların mefta olmuş kanka, ama sorun değil, ses kontrolünü arayüzden hallederiz.' >> /data/local/tmp/checkup_msg");
    }

    // 2. BATARYA SAĞLIĞI (Diyaliz Hastası Modu)
    int batt = get_battery_level(); 
    if (batt < 20) {
        printf("\033[1;31m[KRİTİK]\033[0m Batarya ömrü bitti!\n");
        system("echo 'Kanka batarya artık ölü. Beni ya bir powerbanke bağlı, diyalize bağlı hasta gibi kullanacaksın ya da bir batarya değişimi şart.' > /data/local/tmp/batt_msg");
    } else {
        system("echo 'Bataryam taş gibi, uzun süre idare ederiz.' > /data/local/tmp/batt_msg");
    }

    // 3. DONANIM PING TESTLERİ
    printf("[PING] İç aksamlar dürtülüyor...\n");
    
    // Hoparlör ve Jak Testi
    if (system("speaker-test -t sine -f 440 -l 1 > /dev/null 2>&1") != 0) {
        printf("\033[1;31m[PING_FAIL]\033[0m Hoparlörler sessiz!\n");
        system("echo 'Hoparlörler mefta, Bluetooth kulaklık takarsan ses alabiliriz.' >> /data/local/tmp/checkup_msg");
    } else {
        printf("\033[1;36m[PING_SUCCESS]\033[0m Ses sistemi canlı.\n");
    }

    // Kamera Testi
    if (system("ls /dev/video0 > /dev/null 2>&1") != 0) {
        printf("\033[1;31m[PING_FAIL]\033[0m Kamera hattı kopuk!\n");
        system("echo 'Gözlerimi göremiyorum kanka, kamera hattı kopuk.' >> /data/local/tmp/checkup_msg");
    }

    // Flaş Testi
    if (system("echo 1 > /sys/class/leds/torch/brightness 2>/dev/null") == 0) {
        printf("\033[1;36m[PING_SUCCESS]\033[0m Flaş patladı, ışıklar yerinde!\n");
        system("echo 0 > /sys/class/leds/torch/brightness 2>/dev/null");
    }

    // --- SONUÇLARI SESLENDİR ---
    speak("Beni çekmeceden kurtardın sağ ol kanka. Şimdi kısa bir donanım taraması yaptım, durumumuz şu:");
    
    // Metinleri doğrudan TTS'e gönder ve sonrasında çöp bırakmamak için dosyaları sil
    system("cat /data/local/tmp/checkup_msg /data/local/tmp/batt_msg | espeak -v tr --stdout | aplay > /dev/null 2>&1");
    system("rm -f /data/local/tmp/checkup_msg /data/local/tmp/batt_msg");
}
